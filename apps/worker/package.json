{
  "name": "@faceless/worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "echo \"worker runs via tsx, no build step\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@faceless/avatar-core": "workspace:*",
    "@resvg/resvg-js": "2.6.2",
    "bullmq": "5.34.3",
    "ioredis": "5.4.1",
    "@aws-sdk/client-s3": "3.699.0",
    "@prisma/client": "5.22.0",
    "tsx": "4.19.2"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "typescript": "5.6.3",
    "vitest": "2.1.8",
    "prisma": "5.22.0"
  }
}
