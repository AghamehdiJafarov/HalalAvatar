{
  "name": "faceless-avatar-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter ./packages/** build",
    "build:assets": "pnpm --filter @faceless/assets build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "prisma:migrate": "pnpm --filter @faceless/web prisma migrate dev"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.2",
    "vitest": "2.1.8",
    "eslint": "9.15.0",
    "prettier": "3.3.3"
  }
}
